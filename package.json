<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --credion-blue:#0F63FD;
  --blue:#0F63FD;
  --blue-deep:#072B6E;
  --blue-mid:#114CB4;
  --blue-darkest:#061B43;
  --blue-faint:#EEF5FF;
  --blue-faint2:#DCEAFF;
  --orange:#F28C28;
  --orange-deep:#D76F12;
  --orange-faint:#FFF4E8;
  --ink:#171717;
  --ink-2:#3D4351;
  --ink-3:#6B7280;
  --ink-4:#9AA3B2;
  --surface:#FFFFFF;
  --page:#F4F1EC;
  --page-2:#EDE9E2;
  --rule:#E4DED5;
  --rule-2:#D8CEC0;
  --green:#22825D;
  --green-bg:#EDF8F2;
  --amber:#9A6500;
  --amber-bg:#FFF6E4;
  --red:#9B2C2C;
  --red-bg:#FFF0F0;
  --shadow-sm:0 2px 8px rgba(0,0,0,.05),0 0 0 1px rgba(0,0,0,.035);
  --shadow-md:0 8px 28px rgba(0,0,0,.075),0 1px 6px rgba(0,0,0,.04);
  --shadow-xl:0 20px 64px rgba(0,0,0,.10),0 4px 16px rgba(0,0,0,.05);
  --font:'DM Sans','Segoe UI',system-ui,sans-serif;
}
html{font-size:16px;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
body{font-family:var(--font);background:var(--page);min-height:100vh;color:var(--ink);padding:0 0 80px;line-height:1.55}
button,input,textarea{font:inherit}button{cursor:pointer}button:disabled{cursor:not-allowed}.hidden{display:none!important}
.trust-bar{background:linear-gradient(135deg,var(--blue-deep) 0%,var(--blue-mid) 100%);padding:10px 24px;display:flex;align-items:center;justify-content:center;gap:32px;flex-wrap:wrap;border-bottom:3px solid var(--orange)}
.trust-item{display:flex;align-items:center;gap:8px;color:rgba(255,255,255,.72);font-size:11.5px;letter-spacing:.2px}.trust-item strong{color:#fff;font-weight:700}.trust-dot{width:6px;height:6px;border-radius:50%;background:var(--orange);box-shadow:0 0 0 4px rgba(242,140,40,.12)}
.page-wrap{max-width:820px;margin:0 auto;padding:40px 20px 0}.card{background:var(--surface);border-radius:22px;box-shadow:var(--shadow-xl);overflow:hidden;margin-bottom:16px}.hdr{background:linear-gradient(135deg,var(--blue-deep) 0%,#0B3D91 62%,var(--blue) 100%);padding:28px 40px;display:flex;align-items:center;justify-content:space-between;position:relative;overflow:hidden}.hdr::before{content:'';position:absolute;top:-72px;right:-72px;width:230px;height:230px;border-radius:50%;background:rgba(255,255,255,.055)}.hdr::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--orange),#FFB067)}
.hdr-logo{display:flex;align-items:center;gap:14px;color:#fff;position:relative;z-index:1}.logo-mark{width:54px;height:54px;border-radius:50%;background:#fff;color:var(--blue-deep);display:flex;align-items:center;justify-content:center;font-weight:800;letter-spacing:-.08em;font-size:19px;box-shadow:0 8px 20px rgba(0,0,0,.12)}.hdr-name{font-size:17px;font-weight:800;letter-spacing:.1px}.hdr-sub{font-size:11px;color:rgba(255,255,255,.55);margin-top:2px;letter-spacing:.4px}.hdr-right{text-align:right;position:relative;z-index:1}.hdr-tag{font-size:9px;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.45);font-weight:700;margin-bottom:4px}.hdr-title{font-size:15px;font-weight:700;color:#fff;letter-spacing:-.2px}
.body{padding:38px 40px 40px}.eyebrow{font-size:10.5px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--orange);display:inline-flex;align-items:center;gap:10px;margin-bottom:14px}.eyebrow::before{content:'';width:24px;height:1.5px;background:var(--orange)}.h1{font-size:32px;line-height:1.12;font-weight:700;color:var(--blue-deep);letter-spacing:-.7px;margin-bottom:14px}.h1 em{font-style:italic;color:var(--orange);font-weight:600}.lead{font-size:14px;color:var(--ink-3);line-height:1.7;margin-bottom:28px}.sec-head{display:flex;align-items:center;gap:10px;margin:28px 0 18px}.sec-label{font-size:10px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--ink-4);white-space:nowrap;border-left:2px solid var(--orange);padding-left:7px}.sec-line{flex:1;height:1px;background:var(--rule)}
.up-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}.dropzone{border:1.5px dashed var(--rule-2);border-radius:16px;padding:24px 18px 22px;text-align:center;cursor:pointer;transition:all .25s cubic-bezier(.4,0,.2,1);background:var(--page);position:relative;min-height:186px;display:flex;flex-direction:column;align-items:center;justify-content:center}.dropzone:hover,.dropzone.drag{border-color:var(--blue);background:var(--blue-faint)}.dropzone.has-file{border-color:var(--green);border-style:solid;background:var(--green-bg)}.dz-icon{width:46px;height:46px;border-radius:12px;background:#fff;display:flex;align-items:center;justify-content:center;border:1px solid var(--rule);margin-bottom:11px;color:var(--blue);box-shadow:var(--shadow-sm)}.dropzone.has-file .dz-icon{color:var(--green)}.dz-title{font-size:13.5px;font-weight:800;color:var(--ink);margin-bottom:3px}.dz-sub{font-size:11.5px;color:var(--ink-3);line-height:1.55}.dz-sub strong{color:var(--blue)}.dz-input{position:absolute;inset:0;opacity:0;cursor:pointer}.dz-pill{display:none;background:#fff;border:1px solid rgba(34,130,93,.2);border-radius:9px;padding:8px 11px;margin-top:11px;text-align:left;align-items:center;gap:9px;width:100%}.dz-pill.on{display:flex}.fp-name{font-size:11px;font-weight:700;color:var(--ink);word-break:break-all;line-height:1.3}.fp-size{font-size:10px;color:var(--ink-4);margin-top:2px}.fp-ok{width:18px;height:18px;border-radius:50%;background:var(--green);color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-left:auto}
.field{margin-top:18px}.field label{display:block;font-size:10px;font-weight:800;letter-spacing:1.8px;text-transform:uppercase;color:var(--ink-4);border-left:2px solid var(--orange);padding-left:8px;margin-bottom:9px}.field textarea,.field input[type=text]{width:100%;border:1px solid var(--rule);background:#fff;border-radius:13px;padding:13px 14px;outline:0;color:var(--ink-2);font-size:13px;line-height:1.55;transition:.18s}.field textarea{min-height:104px;resize:vertical}.field textarea:focus,.field input:focus{border-color:var(--blue);box-shadow:0 0 0 4px rgba(15,99,253,.08)}.fineprint{font-size:11.5px;color:var(--ink-3);line-height:1.55;margin-top:9px}
.progress{height:3px;background:var(--rule);border-radius:99px;overflow:hidden;margin:18px 0 0;display:none}.progress.on{display:block}.progress-fill{height:100%;width:0;background:linear-gradient(90deg,var(--blue) 0%,var(--orange) 100%);transition:width .35s ease}.up-error{display:none;margin:14px 0 0;padding:12px 14px;background:var(--red-bg);border:1px solid rgba(155,44,44,.15);border-radius:10px;font-size:13px;color:var(--red);align-items:flex-start;gap:10px;white-space:pre-wrap}.up-error.on{display:flex}.actions{margin-top:24px;display:grid;gap:10px}.btn-primary{width:100%;height:54px;background:var(--blue-deep);color:#fff;border:none;border-radius:12px;font-size:13.5px;font-weight:800;letter-spacing:.3px;display:flex;align-items:center;justify-content:center;gap:10px;box-shadow:0 4px 18px rgba(7,43,110,.16);transition:.2s}.btn-primary:hover:not(:disabled){background:#061E50;transform:translateY(-1.5px);box-shadow:0 10px 28px rgba(7,43,110,.22)}.btn-primary:disabled{opacity:.36}.btn-secondary{height:42px;background:#fff;color:var(--blue-deep);border:1px solid var(--rule);border-radius:10px;font-size:12px;font-weight:800;display:flex;align-items:center;justify-content:center;gap:8px;transition:.15s}.btn-secondary:hover{border-color:var(--blue);background:var(--blue-faint)}
.bullets{display:grid;grid-template-columns:1fr 1fr;gap:8px 18px;margin-top:20px;padding-top:20px;border-top:1px solid var(--rule)}.bullets div{display:flex;align-items:flex-start;gap:8px;font-size:12px;color:var(--ink-2);line-height:1.5}.bullets div::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--green);margin-top:7px;flex-shrink:0}.loading{display:none;padding:58px 30px;text-align:center}.loading.on{display:block}.loading-orb{width:54px;height:54px;border-radius:50%;background:conic-gradient(from 0deg,transparent 0,var(--blue) 75%,var(--orange) 94%,transparent 100%);margin:0 auto 18px;animation:spin 1.1s linear infinite;position:relative}.loading-orb::after{content:'';position:absolute;inset:6px;border-radius:50%;background:#fff}@keyframes spin{to{transform:rotate(360deg)}}.loading h3{font-size:18px;font-weight:800;color:var(--blue-deep);letter-spacing:-.2px;margin-bottom:6px}.loading p{font-size:12.5px;color:var(--ink-3);margin-bottom:18px}.loading-steps{display:inline-flex;flex-direction:column;gap:7px;text-align:left}.loading-step{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--ink-4)}.loading-step.active{color:var(--blue);font-weight:800}.step-dot{width:6px;height:6px;border-radius:50%;background:currentColor;flex-shrink:0}.loading-step.active .step-dot{animation:pulse 1s ease infinite}@keyframes pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.6);opacity:.6}}
body.report-mode .page-wrap,body.report-mode .trust-bar{display:none!important}.rpt-mode{display:none}body.report-mode .rpt-mode{display:block}.rpt-toolbar{background:var(--blue-deep);padding:14px 28px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;position:sticky;top:0;z-index:50;border-bottom:3px solid var(--orange)}.rpt-tb-brand{display:flex;align-items:center;gap:11px;color:#fff}.rpt-tb-mark{width:38px;height:38px;border-radius:50%;background:#fff;color:var(--blue-deep);display:flex;align-items:center;justify-content:center;font-weight:900;letter-spacing:-.08em}.rpt-tb-title{font-size:14px;font-weight:800;color:#fff}.rpt-tb-sub{font-size:10.5px;color:rgba(255,255,255,.55);letter-spacing:.4px;margin-top:1px}.rpt-tb-actions{display:flex;gap:10px;flex-wrap:wrap}.btn-orange{height:42px;background:var(--orange);color:#fff;border:none;border-radius:9px;font-size:12.5px;font-weight:800;display:flex;align-items:center;justify-content:center;gap:9px;padding:0 18px;transition:.15s}.btn-orange:hover{background:var(--orange-deep);transform:translateY(-1px)}.btn-ghost{height:42px;background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.2);border-radius:9px;font-size:12.5px;font-weight:800;display:flex;align-items:center;justify-content:center;gap:9px;padding:0 18px;transition:.15s}.btn-ghost:hover{background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.4)}.rpt-stage{background:var(--page);padding:30px 20px 60px;min-height:calc(100vh - 70px);display:flex;flex-direction:column;align-items:center}
.a4{width:794px;background:#fff;margin:0 auto 24px;box-shadow:0 8px 40px rgba(0,0,0,.07),0 2px 8px rgba(0,0,0,.04);position:relative;overflow:hidden;font-size:11pt;color:var(--ink-2)}.a4.cover{height:1123px}.a4.content{height:1123px;min-height:1123px;max-height:1123px;padding:0 0 62px}.cover-bg{position:absolute;inset:0;background:radial-gradient(circle at 18% 6%,rgba(242,140,40,.22) 0%,transparent 45%),radial-gradient(circle at 90% 92%,rgba(15,99,253,.44) 0%,transparent 50%),linear-gradient(160deg,var(--blue-deep) 0%,var(--blue-darkest) 100%)}.cover-bg::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.028) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.028) 1px,transparent 1px);background-size:48px 48px;mask-image:radial-gradient(ellipse at center,#000 30%,transparent 75%);-webkit-mask-image:radial-gradient(ellipse at center,#000 30%,transparent 75%)}.cover-inner{position:relative;z-index:2;height:100%;padding:42px 50px;display:flex;flex-direction:column;color:#fff}.cover-rule-top{position:absolute;top:24px;left:50px;right:50px;height:1px;background:rgba(255,255,255,.22)}.cover-top{display:flex;justify-content:space-between;align-items:flex-start;padding-top:14px}.cover-brand{display:flex;align-items:center;gap:12px}.cover-brand-mark{width:46px;height:46px;border-radius:50%;background:#fff;color:var(--blue-deep);display:flex;align-items:center;justify-content:center;font-weight:900;letter-spacing:-.08em}.cover-brand-name{font-size:15px;font-weight:800;letter-spacing:.1px}.cover-brand-sub{font-size:10.5px;color:rgba(255,255,255,.6);margin-top:2px;letter-spacing:.2px}.cover-date{font-size:11px;color:rgba(255,255,255,.82);text-align:right;letter-spacing:.3px}.cover-mid{flex:1;display:flex;flex-direction:column;justify-content:flex-end;padding-bottom:18px}.cover-eyebrow{font-size:11px;font-weight:900;letter-spacing:1.8px;text-transform:uppercase;color:#FFB067;margin-bottom:18px;display:flex;align-items:center;gap:14px}.cover-eyebrow::after{content:'';flex:0 0 68px;height:2px;background:#FFB067}.cover-title{font-size:46px;font-weight:750;line-height:1.06;letter-spacing:-1px;color:#fff;margin-bottom:14px;max-width:600px}.cover-sub{font-size:13.5px;color:rgba(255,255,255,.90);max-width:560px;line-height:1.55;margin-bottom:22px}.cover-badges{display:flex;gap:8px;flex-wrap:wrap;margin-top:6px}.cover-badge{font-size:10px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;padding:6px 12px;border-radius:99px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);color:rgba(255,255,255,.88)}.cover-badge.dark{background:rgba(242,140,40,.22);border-color:rgba(242,140,40,.45);color:#fff}.cover-foot{border-top:1px solid rgba(255,255,255,.25);padding-top:18px;display:flex;align-items:center;justify-content:space-between;font-size:10.5px;color:rgba(255,255,255,.76);letter-spacing:.4px}.cover-foot b{color:#fff;font-weight:800}
.page-top{height:58px;background:linear-gradient(135deg,var(--blue-deep) 0%,var(--blue-mid) 100%);display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0 28px;color:#fff;position:relative}.page-top::after{content:'';position:absolute;left:0;right:0;bottom:0;height:3px;background:var(--orange)}.pt-brand{display:flex;align-items:center;gap:10px}.pt-mark{width:30px;height:30px;border-radius:50%;background:#fff;color:var(--blue-deep);display:flex;align-items:center;justify-content:center;font-weight:900;font-size:12px;letter-spacing:-.08em}.pt-name{font-size:11px;font-weight:800;line-height:1.3}.pt-name small{display:block;font-size:9px;color:rgba(255,255,255,.52);font-weight:500;letter-spacing:.3px;margin-top:1px}.pt-mid{text-align:center;line-height:1.12}.pt-mid-name{display:block;font-size:14px;font-weight:800;color:#fff;letter-spacing:-.2px;max-width:340px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.pt-mid-sub{display:block;font-size:9px;font-weight:600;letter-spacing:.2px;color:rgba(255,255,255,.6);margin-top:2px}.pt-right{font-size:9px;font-weight:900;letter-spacing:2.5px;color:rgba(255,255,255,.55);text-align:right}.page-body{padding:26px 44px 0}.page-eyebrow{font-size:10.5px;font-weight:900;letter-spacing:1.4px;text-transform:uppercase;color:var(--orange);margin-bottom:8px}.page-title{font-size:28px;font-weight:750;color:var(--blue-deep);letter-spacing:-.4px;line-height:1.1;margin-bottom:6px}.page-title-sub{font-size:12.5px;color:var(--ink-3);margin-bottom:20px;line-height:1.55}.page-thin-rule{height:2px;background:var(--blue-deep);width:48px;margin:8px 0 18px}.page-stamp{position:absolute;top:60px;right:50px;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--ink-4)}.sec-bar{display:block;background:linear-gradient(135deg,var(--blue-deep) 0%,var(--blue-mid) 100%);color:#fff;font-size:10px;font-weight:900;letter-spacing:2px;text-transform:uppercase;padding:9px 16px;border-radius:8px;border-left:4px solid var(--orange);margin:0 0 16px;-webkit-print-color-adjust:exact;print-color-adjust:exact}
.page-foot{position:absolute;left:0;right:0;bottom:0;height:62px;background:var(--blue-deep);color:#fff;display:grid;grid-template-columns:1.2fr 1.4fr 1fr;align-items:center;padding:0 24px;font-size:9.5px;line-height:1.45}.page-foot::before{content:'';position:absolute;left:0;right:0;top:-2px;height:2px;background:var(--orange)}.pf-l{display:flex;align-items:center;gap:10px}.pf-l-mark{width:26px;height:26px;border-radius:50%;background:#fff;color:var(--blue-deep);display:flex;align-items:center;justify-content:center;font-weight:900;font-size:10px;letter-spacing:-.08em}.pf-l b{color:#fff;font-size:10px;font-weight:800}.pf-l small{display:block;color:rgba(255,255,255,.5);letter-spacing:.3px;margin-top:1px}.pf-m{color:rgba(255,255,255,.55);font-style:italic;text-align:center;padding:0 12px}.pf-r{color:rgba(255,255,255,.7);text-align:right}.pf-r b{display:block;color:#fff;font-weight:800}
.kpi-rapport{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border-radius:14px;overflow:hidden;background:#fff;margin-bottom:16px;box-shadow:0 2px 12px rgba(0,0,0,.06)}.kpi-r-cell{padding:16px 18px 14px;position:relative}.kpi-r-cell:not(:last-child){border-right:1px solid var(--blue-faint)}.kpi-r-lbl{font-size:8.7px;font-weight:900;letter-spacing:1.1px;text-transform:uppercase;color:var(--ink-4);margin-bottom:8px}.kpi-r-val{font-size:22px;font-weight:750;color:var(--blue-deep);line-height:1.08;letter-spacing:-.4px}.kpi-r-val.green{color:var(--green)}.kpi-r-val.orange{color:var(--orange)}.kpi-r-sub{font-size:10.2px;color:var(--ink-3);margin-top:5px;line-height:1.35}.verdict{border-radius:14px;padding:18px 20px;background:linear-gradient(160deg,#F9FBFF 0%,var(--blue-faint) 100%);margin-bottom:14px;box-shadow:0 2px 12px rgba(0,0,0,.05)}.verdict-eyebrow{font-size:9.5px;font-weight:900;letter-spacing:1.2px;text-transform:uppercase;color:var(--orange);margin-bottom:8px}.verdict-title{font-size:17px;font-weight:750;color:var(--blue-deep);margin-bottom:8px;line-height:1.3}.verdict-text{font-size:11.5px;color:var(--ink-2);line-height:1.58}.mgt-bullets{display:grid;grid-template-columns:1fr 1fr;gap:5px 14px;margin-top:10px}.mgt-bullets div{display:flex;gap:7px;font-size:10px;color:var(--ink-3);line-height:1.35}.mgt-bullets div::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--blue);margin-top:5px;flex-shrink:0}
.score-row{display:grid;grid-template-columns:1.15fr .85fr;gap:14px;margin-bottom:14px}.score-card{border-radius:14px;padding:17px 20px;background:linear-gradient(145deg,var(--blue-deep) 0%,var(--blue-mid) 100%);color:#fff;position:relative;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.08)}.score-card::after{content:'';position:absolute;right:-34px;bottom:-48px;width:142px;height:142px;border-radius:50%;background:rgba(255,255,255,.06)}.sc-eyebrow{font-size:9px;font-weight:900;letter-spacing:1.2px;text-transform:uppercase;color:rgba(255,255,255,.62);margin-bottom:8px}.sc-num{font-size:46px;line-height:1;font-weight:800;letter-spacing:-1px}.sc-num small{font-size:18px;color:rgba(255,255,255,.58);font-weight:700}.sc-bar{height:5px;background:rgba(255,255,255,.14);border-radius:99px;margin:11px 0 8px;overflow:hidden}.sc-bar-fill{height:100%;background:linear-gradient(90deg,var(--orange),#FFB067);border-radius:99px}.sc-verdict{font-size:12px;font-weight:800;margin-bottom:6px}.sc-text{font-size:10.3px;color:rgba(255,255,255,.72);line-height:1.42}.score-side{background:#fff;border-radius:14px;padding:11px 14px;box-shadow:0 2px 12px rgba(0,0,0,.06);display:flex;flex-direction:column;justify-content:center;gap:1px}.ss-row{display:flex;justify-content:space-between;align-items:center;font-size:11px;padding:5px 0;border-bottom:1px solid var(--blue-faint)}.ss-row:last-child{border-bottom:none}.ss-l{font-size:10px;color:var(--ink-3);font-weight:700}.ss-v{font-size:11.2px;color:var(--blue-deep);font-weight:800;text-align:right;max-width:170px}
.chart-card{background:#fff;border-radius:14px;padding:15px 17px 12px;margin-bottom:12px;box-shadow:0 2px 12px rgba(0,0,0,.06)}.chart-card-h{font-size:9px;font-weight:900;letter-spacing:1.1px;text-transform:uppercase;color:var(--orange);margin-bottom:4px}.chart-card-t{font-size:12.4px;font-weight:800;color:var(--blue-deep);margin-bottom:8px;line-height:1.3}.chart-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}.chart-grid-3{display:grid;grid-template-columns:1.1fr 1fr 1fr;gap:12px;margin-bottom:12px}.two-col{display:grid;grid-template-columns:1fr 1fr;gap:12px}.col-card{background:#fff;border-radius:14px;padding:15px 17px;box-shadow:0 2px 12px rgba(0,0,0,.06)}.col-h{font-size:9.2px;font-weight:900;letter-spacing:1.8px;text-transform:uppercase;color:var(--orange);margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--rule)}.col-list{display:flex;flex-direction:column;gap:6px}.col-list div{display:flex;gap:9px;align-items:flex-start;font-size:10.8px;color:var(--ink-2);line-height:1.42}.col-list div::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--blue);flex-shrink:0;margin-top:6px}.matrix{display:grid;grid-template-columns:1.2fr repeat(3,1fr);border-radius:14px;overflow:hidden;background:#fff;font-size:10.5px;box-shadow:0 2px 12px rgba(0,0,0,.06)}.matrix>div{padding:8px 10px;border-bottom:1px solid var(--blue-faint);border-right:1px solid var(--blue-faint);line-height:1.28}.matrix>div:nth-child(4n){border-right:none}.matrix>div:nth-last-child(-n+4){border-bottom:none}.matrix .mh{background:var(--page);font-weight:900;font-size:8.5px;letter-spacing:1.4px;text-transform:uppercase;color:var(--ink-3)}.matrix .ml{font-weight:800;color:var(--ink)}.premium-table{width:100%;border-collapse:separate;border-spacing:0;border-radius:14px;overflow:hidden;background:#fff;box-shadow:0 2px 12px rgba(0,0,0,.06);font-size:10.3px;margin-bottom:12px}.premium-table th{background:var(--page);color:var(--ink-3);font-size:8.6px;letter-spacing:1.1px;text-transform:uppercase;text-align:left;padding:9px 10px;font-weight:900}.premium-table td{padding:8.5px 10px;border-top:1px solid var(--blue-faint);vertical-align:top;color:var(--ink-2);line-height:1.35}.premium-table td.num{text-align:right;color:var(--blue-deep);font-weight:800;white-space:nowrap}.tag{display:inline-flex;padding:4px 8px;border-radius:999px;background:var(--blue-faint);color:var(--blue-deep);font-size:8.6px;font-weight:900;letter-spacing:.7px;text-transform:uppercase}.tag.green{background:var(--green-bg);color:var(--green)}.tag.orange{background:var(--orange-faint);color:var(--orange-deep)}.tag.red{background:var(--red-bg);color:var(--red)}.empty{border:1px dashed var(--rule-2);border-radius:12px;padding:12px 14px;background:#FBFAF8;color:var(--ink-3);font-size:11px;line-height:1.45}.note-card{background:#fff;border-radius:14px;padding:14px 16px;box-shadow:0 2px 12px rgba(0,0,0,.06);margin-bottom:12px}.note-card h4{font-size:9px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--orange);margin-bottom:7px}.note-card p{font-size:11px;line-height:1.52;color:var(--ink-2);white-space:pre-line}.fin-strip{display:grid;grid-template-columns:repeat(4,1fr);border-radius:14px;overflow:hidden;background:#fff;margin-bottom:12px;box-shadow:0 2px 12px rgba(0,0,0,.06)}.fin-cell{padding:12px 14px;border-right:1px solid var(--blue-faint)}.fin-cell:last-child{border-right:0}.fin-l{font-size:8.3px;font-weight:900;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink-4);margin-bottom:6px}.fin-v{font-size:18px;font-weight:800;color:var(--blue-deep);line-height:1.1}.fin-s{font-size:9.2px;color:var(--ink-3);margin-top:4px}.close-card{background:linear-gradient(135deg,var(--blue-deep) 0%,var(--blue) 100%);border-radius:14px;padding:24px 28px;color:#fff;position:relative;overflow:hidden;margin-top:14px}.close-card::after{content:'';position:absolute;left:0;right:0;bottom:0;height:3px;background:linear-gradient(90deg,var(--orange),#FFB067)}.close-eyebrow{font-size:9.5px;font-weight:900;letter-spacing:1.2px;text-transform:uppercase;color:#FFB067;margin-bottom:8px}.close-title{font-size:18px;font-weight:800;line-height:1.25;margin-bottom:10px}.close-text{font-size:11.5px;color:rgba(255,255,255,.8);line-height:1.65}.toc-list{display:grid;grid-template-columns:1fr 1fr;gap:0 18px}.toc-item{display:grid;grid-template-columns:34px 1fr;gap:11px;padding:10px 0;border-bottom:1px solid var(--rule)}.toc-n{width:28px;height:28px;border-radius:9px;background:var(--blue-faint);color:var(--blue-deep);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:900}.toc-t{font-size:11.8px;font-weight:900;color:var(--blue-deep);line-height:1.25}.toc-s{font-size:9.5px;color:var(--ink-3);line-height:1.4;margin-top:3px}.mini-bars{display:flex;flex-direction:column;gap:8px}.mini-row{display:grid;grid-template-columns:1fr 92px;gap:10px;align-items:center}.mini-l{font-size:10px;color:var(--ink-2);font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.mini-track{height:8px;background:var(--blue-faint);border-radius:99px;overflow:hidden}.mini-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--orange));border-radius:99px}.mini-v{font-size:10px;color:var(--blue-deep);font-weight:900;text-align:right}
@media(max-width:880px){.page-wrap{max-width:100%;padding:24px 14px}.hdr,.body{padding-left:24px;padding-right:24px}.up-grid,.bullets{grid-template-columns:1fr}.rpt-stage{padding:20px 10px}.a4{width:794px;transform:scale(.48);transform-origin:top center;margin-bottom:-560px}.rpt-toolbar{align-items:flex-start}.rpt-tb-actions{width:100%}}@media(max-width:520px){.hdr{display:block}.hdr-right{text-align:left;margin-top:14px}.h1{font-size:27px}.a4{transform:scale(.39);margin-bottom:-680px}}
@media print{@page{size:210mm 297mm;margin:0}html,body{background:#fff!important;padding:0!important;margin:0!important;width:210mm!important;-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important;color-adjust:exact!important}.trust-bar,.page-wrap,.rpt-toolbar{display:none!important}.rpt-mode{display:block!important}.rpt-stage{display:block!important;padding:0!important;background:#fff!important;min-height:auto!important}.a4{width:210mm!important;height:297mm!important;min-height:297mm!important;max-height:297mm!important;margin:0!important;box-shadow:none!important;page-break-after:always!important;break-after:page!important;overflow:hidden!important}.a4:last-child{page-break-after:auto!important;break-after:auto!important}.page-top{height:46px!important}.page-body{padding:18px 38px 0!important;font-size:9.4pt!important}.page-title{font-size:20px!important;margin-bottom:4px!important}.page-title-sub{font-size:10px!important;margin-bottom:11px!important}.page-thin-rule{margin:5px 0 11px!important}.page-foot{height:52px!important;font-size:8px!important}.page-stamp{top:52px!important;font-size:8px!important}.kpi-r-cell{padding:11px 14px!important}.kpi-r-val{font-size:18px!important}.score-row,.chart-grid-2,.two-col{gap:9px!important}.chart-card{padding:10px 12px 8px!important}.premium-table th,.premium-table td{padding:6px 8px!important}.note-card,.chart-card,.col-card,.verdict,.score-card{break-inside:avoid!important}}
</style>
</head>
<body>
  <div class="trust-bar">
    <div class="trust-item"><span class="trust-dot"></span><strong>Credion MB</strong> Amsterdam &amp; Texel</div>
    <div class="trust-item"><span class="trust-dot"></span>Bankwaardig financieringsmemorandum</div>
    <div class="trust-item"><span class="trust-dot"></span>Geen demo-cijfers · casusdata leidend</div>
  </div>

  <main class="page-wrap" id="appPage">
    <section class="card" id="uploadCard">
      <header class="hdr">
        <div class="hdr-logo"><div class="logo-mark">CM</div><div><div class="hdr-name">Credion MB</div><div class="hdr-sub">Financieringsrapport-generator</div></div></div>
        <div class="hdr-right"><div class="hdr-tag">Premium dossier</div><div class="hdr-title">Capsearch → luxe rapport</div></div>
      </header>
      <div class="body">
        <div class="eyebrow">Financieringsmemorandum</div>
        <h1 class="h1">Upload de casus en genereer een <em>hoogwaardig rapport</em>.</h1>
        <p class="lead">Deze versie volgt de uitstraling van de ESG-tool: premium upload, A4-pagina’s, scorekaarten, risicomatrix, financieringsgrafieken en printklare rapportage in Credion-stijl. De frontend rendert alleen API-data, geen hardcoded voorbeeldrapport.</p>

        <form id="genForm">
          <div class="sec-head"><div class="sec-label">Documenten</div><div class="sec-line"></div></div>
          <div class="up-grid">
            <label class="dropzone" id="dzMain">
              <input class="dz-input" id="mainPdf" type="file" accept="application/pdf,.pdf">
              <div class="dz-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 15V3"/><path d="m7 8 5-5 5 5"/><path d="M20 15v4a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-4"/></svg></div>
              <div class="dz-title">Hoofdmemorandum</div>
              <div class="dz-sub">Upload Capsearch- of financierings-PDF</div>
              <div class="dz-pill" id="mainPill"><div><div class="fp-name"></div><div class="fp-size"></div></div><div class="fp-ok">✓</div></div>
            </label>
            <label class="dropzone" id="dzExtra">
              <input class="dz-input" id="extraPdf" type="file" accept="application/pdf,.pdf" multiple>
              <div class="dz-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M8 13h8"/><path d="M8 17h5"/></svg></div>
              <div class="dz-title">Aanvullende stukken</div>
              <div class="dz-sub">Jaarrekening, balans, taxatie, offerte, KvK</div>
              <div class="dz-pill" id="extraPill"><div><div class="fp-name"></div><div class="fp-size"></div></div><div class="fp-ok">✓</div></div>
            </label>
          </div>

          <div class="field">
            <label for="advisorNotes">Adviseursnotities</label>
            <textarea id="advisorNotes" placeholder="Bijvoorbeeld: neem saneringsvraag mee, markeer periodebalans, werk memo-/buitenbalansposten uit, let op negatieve liquide middelen, gewenste financieringsvorm, looptijd of zekerheden."></textarea>
            <div class="fineprint">Notities wegen mee, maar cijfers blijven alleen geldig wanneer ze uit bron of notitie herleidbaar zijn.</div>
          </div>

          <div class="progress" id="progress"><div class="progress-fill" id="progressFill"></div></div>
          <div class="up-error" id="errorBox"><span>!</span><span id="errorText"></span></div>
          <div class="actions">
            <button class="btn-primary" id="submitBtn" type="submit" disabled>Genereer luxe financieringsrapport</button>
            <button class="btn-secondary" type="button" id="resetBtn">Wis selectie</button>
          </div>
        </form>

        <div class="bullets">
          <div>Volledig A4-rapport met cover, inhoudsopgave, memorandum en bijlagen.</div>
          <div>Luxe grafieken: score, radar, financieringsmix, balans en risicomatrix.</div>
          <div>Credion-stijl: blauw, oranje accent, compacte zakelijke pagina’s.</div>
          <div>Geen voorbeeldcijfers meer in de rapportweergave.</div>
        </div>
      </div>
    </section>

    <section class="card loading" id="loadingCard">
      <div class="loading-orb"></div>
      <h3>Rapport wordt opgebouwd</h3>
      <p>Documenten worden geüpload, geanalyseerd en omgezet naar een bankwaardig Credion-rapport.</p>
      <div class="loading-steps" id="loadingSteps"></div>
    </section>
  </main>

  <section class="rpt-mode" id="reportMode">
    <div class="rpt-toolbar">
      <div class="rpt-tb-brand"><div class="rpt-tb-mark">CM</div><div><div class="rpt-tb-title" id="tbTitle">Financieringsrapport</div><div class="rpt-tb-sub">Credion MB · Concept ter beoordeling</div></div></div>
      <div class="rpt-tb-actions">
        <button class="btn-ghost" type="button" id="downloadJson">Download JSON</button>
        <button class="btn-ghost" type="button" id="newReport">Nieuw rapport</button>
        <button class="btn-orange" type="button" id="printReport">Print / PDF</button>
      </div>
    </div>
    <div class="rpt-stage" id="reportStage"></div>
  </section>

<script type="module">
import { upload } from 'https://esm.sh/@vercel/blob@2.3.3/client';

const $ = (s,r=document)=>r.querySelector(s);
const $$ = (s,r=document)=>Array.from(r.querySelectorAll(s));
const state = { main:null, extras:[], data:null, busy:false, step:0 };
const steps = ['Hoofddocument uploaden','Aanvullende stukken uploaden','AI-analyse starten','Memorandum structureren','Cijfers en grafieken opbouwen','A4-rapport renderen'];
const el = {
  genForm:$('#genForm'), mainPdf:$('#mainPdf'), extraPdf:$('#extraPdf'), dzMain:$('#dzMain'), dzExtra:$('#dzExtra'),
  mainPill:$('#mainPill'), extraPill:$('#extraPill'), submitBtn:$('#submitBtn'), resetBtn:$('#resetBtn'), advisorNotes:$('#advisorNotes'),
  progress:$('#progress'), progressFill:$('#progressFill'), errorBox:$('#errorBox'), errorText:$('#errorText'), uploadCard:$('#uploadCard'), loadingCard:$('#loadingCard'), loadingSteps:$('#loadingSteps'),
  reportStage:$('#reportStage'), reportMode:$('#reportMode'), tbTitle:$('#tbTitle'), printReport:$('#printReport'), newReport:$('#newReport'), downloadJson:$('#downloadJson')
};

function esc(v){return String(v??'').replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('"','&quot;').replaceAll("'",'&#039;')}
function isBlank(v){return v==null||v===''||(Array.isArray(v)&&v.length===0)||(typeof v==='object'&&!Array.isArray(v)&&Object.keys(v).length===0)}
function txt(v,fb='Niet opgenomen in bron'){if(isBlank(v)) return fb;if(typeof v==='object') return Object.entries(v).filter(([,x])=>!isBlank(x)).map(([k,x])=>`${human(k)}: ${Array.isArray(x)?x.join(', '):(typeof x==='object'?txt(x):x)}`).join(' · ')||fb;return String(v)}
function arr(v){return Array.isArray(v)?v.filter(x=>!isBlank(x)):[]}
function human(k){return String(k).replaceAll('_',' ').replaceAll('-',' ').replace(/\b\w/g,c=>c.toUpperCase())}
function n(v){if(typeof v==='number'&&Number.isFinite(v))return v;if(typeof v==='string'){const cleaned=v.replace(/\s/g,'').replace('€','').replaceAll('.','').replace(',','.');const x=Number(cleaned);return Number.isFinite(x)?x:0}return 0}
function clamp(v,min=0,max=100){return Math.max(min,Math.min(max,Number(v)||0))}
function money(v){const x=n(v);if(!x&&String(v??'')&&!/^0+([,.]0+)?$/.test(String(v))) return txt(v);return new Intl.NumberFormat('nl-NL',{style:'currency',currency:'EUR',maximumFractionDigits:0}).format(x)}
function money2(v){const x=n(v);return new Intl.NumberFormat('nl-NL',{style:'currency',currency:'EUR'}).format(x)}
function pct(v){const x=n(v);return `${new Intl.NumberFormat('nl-NL',{maximumFractionDigits:1}).format(x)}%`}
function fileSize(b){return !b?'PDF':`${(b/1024/1024).toFixed(2)} MB`}
function today(){return new Date().toLocaleDateString('nl-NL',{day:'numeric',month:'long',year:'numeric'})}

function setError(msg=''){if(!msg){el.errorBox.classList.remove('on');el.errorText.textContent='';return}el.errorText.textContent=msg;el.errorBox.classList.add('on')}
function setBusy(b){state.busy=b;el.submitBtn.disabled=b||!state.main;el.submitBtn.textContent=b?'Rapport wordt gemaakt...':'Genereer luxe financieringsrapport';el.progress.classList.toggle('on',b);el.uploadCard.classList.toggle('hidden',b);el.loadingCard.classList.toggle('on',b)}
function setStep(i){state.step=i;const pct=Math.round(((i+1)/steps.length)*100);el.progressFill.style.width=`${pct}%`;el.loadingSteps.innerHTML=steps.map((s,idx)=>`<div class="loading-step ${idx===i?'active':''}"><div class="step-dot"></div>${esc(s)}</div>`).join('')}
function updatePill(kind){if(kind==='main'){el.dzMain.classList.toggle('has-file',!!state.main);el.mainPill.classList.toggle('on',!!state.main);if(state.main){$('.fp-name',el.mainPill).textContent=state.main.name;$('.fp-size',el.mainPill).textContent=fileSize(state.main.size)}}else{el.dzExtra.classList.toggle('has-file',state.extras.length>0);el.extraPill.classList.toggle('on',state.extras.length>0);if(state.extras.length){$('.fp-name',el.extraPill).textContent=state.extras.length===1?state.extras[0].name:`${state.extras.length} documenten geselecteerd`;$('.fp-size',el.extraPill).textContent=state.extras.map(f=>fileSize(f.size)).join(' · ')}}el.submitBtn.disabled=!state.main||state.busy}
function resetAll(){state.main=null;state.extras=[];state.data=null;state.busy=false;state.step=0;el.mainPdf.value='';el.extraPdf.value='';el.advisorNotes.value='';updatePill('main');updatePill('extra');setError('');document.body.classList.remove('report-mode');el.reportStage.innerHTML='';el.uploadCard.classList.remove('hidden');el.loadingCard.classList.remove('on');window.scrollTo({top:0,behavior:'smooth'})}

['dragenter','dragover'].forEach(ev=>{[el.dzMain,el.dzExtra].forEach(d=>d.addEventListener(ev,e=>{e.preventDefault();d.classList.add('drag')}))});
['dragleave','drop'].forEach(ev=>{[el.dzMain,el.dzExtra].forEach(d=>d.addEventListener(ev,e=>{e.preventDefault();d.classList.remove('drag')}))});
el.dzMain.addEventListener('drop',e=>{const f=[...e.dataTransfer.files].find(x=>/pdf/i.test(x.type)||/\.pdf$/i.test(x.name));if(f){state.main=f;updatePill('main')}});
el.dzExtra.addEventListener('drop',e=>{state.extras=[...e.dataTransfer.files].filter(x=>/pdf/i.test(x.type)||/\.pdf$/i.test(x.name));updatePill('extra')});
el.mainPdf.addEventListener('change',e=>{state.main=e.target.files[0]||null;updatePill('main')});
el.extraPdf.addEventListener('change',e=>{state.extras=[...e.target.files];updatePill('extra')});
el.resetBtn.addEventListener('click',resetAll);el.newReport.addEventListener('click',resetAll);el.printReport.addEventListener('click',()=>window.print());el.downloadJson.addEventListener('click',downloadJson);
el.genForm.addEventListener('submit',generateReport);
setStep(0);

async function uploadPdf(file,label){const clean=file.name.replace(/[^a-zA-Z0-9._-]+/g,'-');return upload(clean,file,{access:'public',handleUploadUrl:'/api/upload',clientPayload:JSON.stringify({label})})}
async function generateReport(e){
  e.preventDefault();if(!state.main||state.busy)return;setError('');setBusy(true);
  try{
    setStep(0);const mainBlob=await uploadPdf(state.main,'memorandum');
    setStep(1);const extraBlobs=[];for(let i=0;i<state.extras.length;i++){extraBlobs.push(await uploadPdf(state.extras[i],`extra-${i+1}`))}
    setStep(2);const resp=await fetch('/api/generate-report',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({memorandum_url:mainBlob.url,extra_urls:extraBlobs.map(b=>b.url),notities:el.advisorNotes.value||''})});
    const payload=await resp.json().catch(()=>({}));if(!resp.ok||payload.error)throw new Error(payload.error||`API-fout ${resp.status}`);
    setStep(3);let data=payload.data??payload;if(typeof data==='string'){try{data=JSON.parse(data)}catch{throw new Error('API gaf een JSON-string terug die niet parsebaar is.')}}if(!data||typeof data!=='object'||Array.isArray(data))throw new Error('API gaf geen geldig rapportobject terug.');
    setStep(4);state.data=data;setStep(5);renderReport(data);
  }catch(err){console.error(err);setError(err.message||'Rapport genereren mislukt. Controleer OPENAI_API_KEY, Blob-token en JSON-output.');}
  finally{setBusy(false)}
}
function downloadJson(){if(!state.data)return;const blob=new Blob([JSON.stringify(state.data,null,2)],{type:'application/json'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='credion-financieringsrapport.json';a.click();URL.revokeObjectURL(a.href)}

function normalize(raw){
  const meta=raw.rapport_meta||{};const cover=raw.cover||{};const s=raw.managementsamenvatting||raw.samenvatting||{};const oldStruct=raw.structuur||{};const newStruct=raw.juridische_structuur||{};const fin=raw.financieringsvraag||raw.financieringsbehoefte||{};const doc=raw.documentatiecheck||{};
  const klant=meta.klant||cover.klantnaam||raw.klant||s.kredietnemer||'Nog te controleren';
  const datum=meta.rapportdatum||cover.datum||raw.datum_rapport||today();
  const visual=raw.visualisatie_data||{};
  const scoreObj=visual.rapport_score||raw.rapport_score||{};
  const score=n(scoreObj.score)||calcCompleteness(raw);
  const financieringsmix=arr(visual.financieringsmix).length?visual.financieringsmix:arr(fin.specificatie);
  const secMix=arr(visual.zekerhedenmix);
  const radar=arr(visual.radar).length?visual.radar:defaultRadar(raw);
  return {raw,klant,datum,status:meta.status||s.status||'Concept · ter beoordeling',rapporttype:meta.rapporttype||'Financieringsmemorandum',bronbasis:meta.bronbasis||'Aangeleverde brondocumenten',disclaimer:meta.disclaimer||'Concept op basis van aangeleverde informatie. Finale beoordeling door adviseur en financier.',cover:{titel:cover.titel||'Financieringsmemorandum',subtitel:cover.subtitel||'Bankwaardig rapport · Credion MB Amsterdam & Texel',plaats:cover.plaats||'Amsterdam / Texel',adviseur:cover.adviseur||'Credion MB Amsterdam & Texel'},toc:buildToc(raw),memo:raw.memorandum||{},s,j:{...oldStruct,...newStruct,betrokken_partijen:arr(newStruct.betrokken_partijen).length?newStruct.betrokken_partijen:oldStruct.betrokken_partijen,organogram:arr(newStruct.organogram).length?newStruct.organogram:oldStruct.organogram,bestuur_en_tekenbevoegdheid:arr(newStruct.bestuur_en_tekenbevoegdheid).length?newStruct.bestuur_en_tekenbevoegdheid:oldStruct.tekenbevoegd},activiteiten:raw.activiteiten||{},fin,bestaande:raw.bestaande_financieringen||{},nieuwe:raw.nieuwe_financiering||{},fa:raw.financiele_analyse||{},balans:raw.balans||{},zekerheden:raw.zekerheden||{},risico:raw.risicoanalyse||{},doc:raw.documentatie||doc,doccheck:doc,adviseur:raw.adviseur_check||{},bijlagen:raw.bijlagen||{},controles:raw.agent_controles||{},charts:{score,scoreLabel:scoreObj.label||scoreLabel(score),scoreText:scoreObj.toelichting||'Datadekking en rapportvolledigheid op basis van de gevulde JSON-velden.',radar,financieringsmix,zekerhedenmix:secMix,risicomatrix:arr(visual.risicomatrix)}}
}
function calcCompleteness(o){let total=0,filled=0;function walk(x){if(total>220)return;if(Array.isArray(x)){total++;if(x.length)filled++;x.slice(0,8).forEach(walk)}else if(x&&typeof x==='object'){Object.values(x).forEach(walk)}else{total++;if(!isBlank(x)&&x!==0)filled++}}walk(o);return clamp(Math.round((filled/Math.max(total,1))*100),30,98)}
function scoreLabel(s){return s>=85?'Sterk onderbouwd':s>=70?'Goed bruikbaar':s>=55?'Bruikbaar met checks':'Aanvullen vereist'}
function defaultRadar(raw){return [{label:'Datadekking',waarde:calcCompleteness(raw)},{label:'Cijferbasis',waarde:n(raw.agent_controles?.cijfers_gevonden)?clamp(45+n(raw.agent_controles.cijfers_gevonden)*5):50},{label:'Zekerheden',waarde:arr(raw.zekerheden?.nieuw).length||arr(raw.zekerheden?.bestaand).length?76:42},{label:'Risico-inzicht',waarde:arr(raw.risicoanalyse?.risicos).length?74:45},{label:'Documentatie',waarde:arr(raw.documentatiecheck?.ontvangen).length||arr(raw.documentatie).length?72:44}]}
function buildToc(raw){const supplied=arr(raw.inhoudsopgave);if(supplied.length)return supplied.map((x,i)=>({nr:String(x.hoofdstuk||i+1).padStart(2,'0'),titel:x.titel||`Hoofdstuk ${i+1}`,sub:arr(x.subparagrafen).join(' · ')}));return [['01','Cover & rapportinformatie','Klant · datum · status · vertrouwelijkheid'],['02','Managementsamenvatting','KPI’s · score · financieringsprofiel · conclusie'],['03','Memorandum','Aanleiding · kern aanvraag · besluitvorming'],['04','Inhoudsopgave','Volledige index van het rapport'],['05','Aanvrager & juridische structuur','Partijen · UBO · bevoegdheden'],['06','Activiteiten onderneming','Verdienmodel · marktpositie · aandachtspunten'],['07','Financieringsvraag','Doel · specificatie · onderbouwing'],['08','Financiële analyse','Resultaat · balans · kasstroom · ratio’s'],['09','Balans & memoposten','Activa · passiva · memo/buitenbalans'],['10','Zekerheden & risicoanalyse','Dekking · risicomatrix · mitiganten'],['11','Documentatiecheck','Ontvangen · op te vragen · ontbrekend'],['12','Adviseur-check & bijlagen','Inconsistenties · actiepunten · controles']].map(x=>({nr:x[0],titel:x[1],sub:x[2]}))}

function renderReport(raw){const d=normalize(raw);el.tbTitle.textContent=d.klant;el.reportStage.innerHTML=[cover(d),summary(d),memoPage(d),tocPage(d),structurePage(d),financeNeedPage(d),financialPage(d),balancePage(d),riskPage(d),documentationPage(d),advisorPage(d),closingPage(d)].join('');document.body.classList.add('report-mode');window.scrollTo({top:0,behavior:'smooth'})}
function foot(d,label){return `<div class="page-foot"><div class="pf-l"><div class="pf-l-mark">CM</div><div><b>Credion MB</b><small>Amsterdam & Texel</small></div></div><div class="pf-m">${esc(d.disclaimer)}</div><div class="pf-r"><b>${esc(label)}</b>${esc(d.datum)}</div></div>`}
function top(d,stamp){return `<div class="page-top"><div class="pt-brand"><div class="pt-mark">CM</div><div class="pt-name">Credion MB<small>Amsterdam & Texel</small></div></div><div class="pt-mid"><span class="pt-mid-name">${esc(d.klant)}</span><span class="pt-mid-sub">${esc(d.rapporttype)}</span></div><div class="pt-right">${esc(stamp)}</div></div>`}
function page(d,stamp,eyebrow,title,sub,body,cls=''){return `<article class="a4 content ${cls}">${top(d,stamp)}<div class="page-stamp">${esc(stamp)}</div><div class="page-body"><div class="page-eyebrow">${esc(eyebrow)}</div><h2 class="page-title">${esc(title)}</h2><p class="page-title-sub">${esc(sub)}</p><div class="page-thin-rule"></div>${body}</div>${foot(d,stamp)}</article>`}
function cover(d){return `<article class="a4 cover"><div class="cover-bg"></div><div class="cover-inner"><div class="cover-rule-top"></div><div class="cover-top"><div class="cover-brand"><div class="cover-brand-mark">CM</div><div><div class="cover-brand-name">Credion MB</div><div class="cover-brand-sub">Amsterdam & Texel</div></div></div><div class="cover-date">${esc(d.datum)}<br>${esc(d.status)}</div></div><div class="cover-mid"><div class="cover-eyebrow">${esc(d.rapporttype)}</div><h1 class="cover-title">${esc(d.cover.titel)}</h1><p class="cover-sub">${esc(d.cover.subtitel)}<br><b>${esc(d.klant)}</b></p><div class="cover-badges"><span class="cover-badge dark">Vertrouwelijk</span><span class="cover-badge">Concept ter beoordeling</span><span class="cover-badge">Bron: ${esc(d.bronbasis)}</span></div></div><div class="cover-foot"><span><b>${esc(d.cover.adviseur)}</b></span><span>${esc(d.cover.plaats)}</span></div></div></article>`}
function summary(d){const s=d.s;return page(d,'02 · 12','Managementsamenvatting','Kern van de financieringscasus','Bankwaardige samenvatting met financieringsbehoefte, profielscore, datadekking en belangrijkste aandachtspunten.',`${kpiStrip([[ 'Kredietnemer',s.kredietnemer||d.klant,d.status ],['Financieringsdoel',s.financieringsdoel,'Doel aanvraag'],['Totale behoefte',money(s.totale_behoefte||d.fin.totaal),'Bronbedrag'],['Financieringsvorm',s.financieringsvorm||d.nieuwe.vorm,'Structuur'],['Looptijd',s.looptijd_mnd?`${s.looptijd_mnd} mnd`:d.nieuwe.looptijd_mnd?`${d.nieuwe.looptijd_mnd} mnd`:'Niet in bron','Indicatief'],['Zekerheden',s.belangrijkste_zekerheden,'Samenvatting']])}<div class="score-row"><div class="score-card"><div class="sc-eyebrow">Rapportscore</div><div class="sc-num">${esc(d.charts.score)}<small>/100</small></div><div class="sc-bar"><div class="sc-bar-fill" style="width:${esc(d.charts.score)}%"></div></div><div class="sc-verdict">${esc(d.charts.scoreLabel)}</div><div class="sc-text">${esc(d.charts.scoreText)}</div></div><div class="score-side">${scoreRows([['Status',d.status],['Bronbasis',d.bronbasis],['Memo toegevoegd',d.controles.memo_toegevoegd?'Ja':'Controleer'],['Index',d.controles.index_volledig?'Volledig':'Volledig stramien']])}</div></div><div class="chart-grid-2"><div class="chart-card"><div class="chart-card-h">Grafiek</div><div class="chart-card-t">Financieringsmix</div>${barChart(d.charts.financieringsmix,'bedrag')}</div><div class="chart-card"><div class="chart-card-h">Grafiek</div><div class="chart-card-t">Radar datakwaliteit</div>${radarChart(d.charts.radar)}</div></div><div class="verdict"><div class="verdict-eyebrow">Conceptconclusie</div><div class="verdict-title">${esc(txt(s.conclusie,'Conclusie aanvullen door adviseur'))}</div><div class="verdict-text">${listInline(arr(s.belangrijkste_aandachtspunten).length?s.belangrijkste_aandachtspunten:s.aandachtspunten)}</div></div>`,'page-summary')}
function memoPage(d){const m=d.memo;return page(d,'03 · 12','Memorandum','Executive memorandum','Zelfstandig leesbare memo voor bank, financier, leasepartij of bijzonder beheer.',`<div class="two-col">${note('Aanleiding',m.aanleiding,true)}${note('Kern van de aanvraag',m.kern_van_de_aanvraag||m.kern_aanvraag,true)}${note('Betrokken partijen',m.betrokken_partijen)}${note('Financiële positie',m.financiele_positie)}${note('Financieringsbehoefte / saneringsvraag',m.financieringsbehoefte||m.saneringsvraag)}${note('Bestaande verplichtingen',m.bestaande_verplichtingen)}${note('Zekerheden',m.zekerheden)}${note('Risico’s en aandachtspunten',m.risicos_en_aandachtspunten||m.risicoanalyse)}${note('Benodigde besluitvorming',m.benodigde_besluitvorming)}${note('Conceptconclusie',m.conceptconclusie||m.conclusie,true)}</div>`)}
function tocPage(d){return page(d,'04 · 12','Index','Inhoudsopgave','Uitgebreide inhoudsopgave voor een volledig financieringsmemorandum.',`<div class="toc-list">${d.toc.map(x=>`<div class="toc-item"><div class="toc-n">${esc(x.nr)}</div><div><div class="toc-t">${esc(x.titel)}</div><div class="toc-s">${esc(x.sub||'')}</div></div></div>`).join('')}</div>`)}
function structurePage(d){const j=d.j, a=d.activiteiten;return page(d,'05 · 12','Aanvrager & structuur','Partijen, activiteiten en bevoegdheden','Overzicht van juridische structuur, onderneming, bestuur/tekenbevoegdheid en activiteiten.',`<div class="sec-bar">Juridische structuur</div><div class="two-col"><div>${table('Betrokken partijen',arr(j.betrokken_partijen),['partij','rol','rechtsvorm','kvk'])}</div><div>${table('Bestuur / tekenbevoegd',arr(j.bestuur_en_tekenbevoegdheid),['naam','rol','bevoegdheid'])}</div></div><div class="two-col"><div class="col-card"><div class="col-h">Activiteiten</div><div class="col-list"><div>${esc(txt(a.beschrijving))}</div><div>${esc(txt(a.verdienmodel||a.toegevoegde_waarde))}</div><div>${esc(txt(a.marktpositie))}</div></div></div><div class="col-card"><div class="col-h">Aandachtspunten</div><div class="col-list">${listItems(arr(j.aandachtspunten).concat(arr(a.aandachtspunten)))}</div></div></div>${table('UBO / aandeelhouders',arr(j.ubo_aandeelhouders),['naam','belang','toelichting'])}`)}
function financeNeedPage(d){const f=d.fin, nw=d.nieuwe, b=d.bestaande;return page(d,'06 · 12','Financieringsvraag','Behoefte, structuur en bestaande financiering','Specificatie van de gevraagde financiering, bestaande verplichtingen en nieuwe voorwaarden.',`${kpiStrip([['Doel',f.doel||d.s.financieringsdoel,'Aanvraag'],['Totale behoefte',money(f.totaal||d.s.totale_behoefte),'Specificatie'],['Nieuwe hoofdsom',money(nw.hoofdsom),'Structuur'],['Looptijd',nw.looptijd_mnd?`${nw.looptijd_mnd} mnd`:'Niet in bron','Voorwaarde'],['Rente',nw.rente_pct?pct(nw.rente_pct):nw.rekenrente_pct?pct(nw.rekenrente_pct):'Niet in bron','Indicatief'],['Maandlast',money(nw.maandlast_indicatief),'Indicatief']])}<div class="chart-grid-2"><div class="chart-card"><div class="chart-card-h">Specificatie</div><div class="chart-card-t">Financieringsbehoefte</div>${barChart(arr(f.specificatie),'bedrag')}</div><div class="chart-card"><div class="chart-card-h">Bestaand</div><div class="chart-card-t">Leningen en verplichtingen</div>${barChart(arr(b.leningen).concat(arr(b.rekening_courant),arr(b.leaseverplichtingen),arr(b.overige_schulden)).map(x=>({label:x.soort||x.verstrekker||x.post||x.label,bedrag:x.restschuld||x.bedrag})), 'bedrag')}</div></div><div class="two-col"><div class="col-card"><div class="col-h">Onderbouwing</div><div class="col-list"><div>${esc(txt(f.onderbouwing))}</div><div>${esc(txt(f.effect_op_onderneming||f.effect))}</div></div></div><div class="col-card"><div class="col-h">Aandachtspunten</div><div class="col-list">${listItems(arr(f.aandachtspunten).concat(arr(nw.aandachtspunten),arr(b.aandachtspunten)))}</div></div></div>`)}
function financialPage(d){const fa=d.fa;return page(d,'07 · 12','Financiële analyse','Resultaat, kasstroom en ratio’s','Financiële analyse op basis van brondata, inclusief visualisaties en aandachtspunten.',`<div class="verdict"><div class="verdict-eyebrow">Financiële samenvatting</div><div class="verdict-title">${esc(txt(fa.samenvatting,'Financiële samenvatting niet opgenomen in bron'))}</div><div class="verdict-text">${esc(txt(fa.kasstroomanalyse,'Kasstroomanalyse aanvullen indien brondata beschikbaar is'))}</div></div><div class="chart-grid-2"><div class="chart-card"><div class="chart-card-h">Trend</div><div class="chart-card-t">Resultaat / ratio ontwikkeling</div>${trendChart(arr(fa.resultatenanalyse).concat(arr(fa.ratio_analyse)))}</div><div class="chart-card"><div class="chart-card-h">Ratio’s</div><div class="chart-card-t">Financiële kernindicatoren</div>${miniBars(arr(fa.ratio_analyse).map(x=>({label:x.ratio||x.label||x.naam,waarde:n(x.waarde||x.score||x.percentage)})))}</div></div><div class="two-col"><div>${table('Resultatenanalyse',arr(fa.resultatenanalyse),['jaar','post','bedrag','toelichting'])}</div><div>${table('Balansanalyse',arr(fa.balansanalyse),['peildatum','post','bedrag','toelichting'])}</div></div><div class="col-card"><div class="col-h">Aandachtspunten</div><div class="col-list">${listItems(arr(fa.aandachtspunten).concat(arr(fa.ontwikkelingen)))}</div></div>`)}
function balancePage(d){const b=d.balans;return page(d,'08 · 12','Balansanalyse','Activa, passiva en memo-/buitenbalansposten','Balanssectie met peildata, specificaties en controle of activa en passiva sluiten.',`<div class="fin-strip"><div class="fin-cell"><div class="fin-l">Peildata</div><div class="fin-v">${esc(arr(b.peildata).length||'0')}</div><div class="fin-s">Aantal bronstanden</div></div><div class="fin-cell"><div class="fin-l">Activa</div><div class="fin-v">${money(sum(arr(b.activa),'bedrag'))}</div><div class="fin-s">Som opgenomen posten</div></div><div class="fin-cell"><div class="fin-l">Passiva</div><div class="fin-v">${money(sum(arr(b.passiva),'bedrag'))}</div><div class="fin-s">Som opgenomen posten</div></div><div class="fin-cell"><div class="fin-l">Verschil</div><div class="fin-v">${money(b.controle?.verschil)}</div><div class="fin-s">${esc(txt(b.controle?.toelichting,'Controle op basis van bron'))}</div></div></div><div class="chart-grid-2"><div class="chart-card"><div class="chart-card-h">Activa</div><div class="chart-card-t">Balansposten activa</div>${barChart(arr(b.activa),'bedrag')}</div><div class="chart-card"><div class="chart-card-h">Passiva</div><div class="chart-card-t">Balansposten passiva</div>${barChart(arr(b.passiva),'bedrag')}</div></div><div class="two-col"><div>${table('Specificaties',arr(b.specificaties),['peildatum','rubriek','post','bedrag'])}</div><div>${table('Memo- en buitenbalansposten',arr(b.memo_en_buitenbalansposten),['label','post','bedrag','toelichting'])}</div></div>`)}
function riskPage(d){const z=d.zekerheden, r=d.risico;const matrix=arr(d.charts.risicomatrix).length?d.charts.risicomatrix:arr(r.risicos);return page(d,'09 · 12','Zekerheden & risicoanalyse','Dekking, risicomatrix en mitiganten','Overzicht van bestaande en nieuwe zekerheden, zekerheidsstellers en bancaire aandachtspunten.',`<div class="chart-grid-2"><div class="chart-card"><div class="chart-card-h">Grafiek</div><div class="chart-card-t">Zekerhedenmix</div>${barChart(d.charts.zekerhedenmix.length?d.charts.zekerhedenmix:arr(z.nieuw).concat(arr(z.bestaand)).map(x=>({label:x.type||x.omschrijving,bedrag:x.waarde||x.bedrag||0})), 'bedrag')}</div><div class="chart-card"><div class="chart-card-h">Matrix</div><div class="chart-card-t">Risico-inschatting</div>${riskMatrix(matrix)}</div></div><div class="two-col"><div>${table('Zekerheden',arr(z.nieuw).concat(arr(z.bestaand)),['type','omschrijving','categorie','waarde'])}</div><div class="col-card"><div class="col-h">Bancaire aandachtspunten</div><div class="col-list">${listItems(arr(r.bancaire_aandachtspunten).concat(arr(z.aandachtspunten)))}</div></div></div><div class="verdict"><div class="verdict-eyebrow">Risicoconclusie</div><div class="verdict-title">${esc(txt(r.conclusie,'Risicoconclusie aanvullen door adviseur'))}</div><div class="verdict-text">${listInline(arr(r.mitiganten))}</div></div>`,'page-risk')}
function documentationPage(d){const doc=d.doccheck;const flat=Array.isArray(d.doc)?d.doc:[];return page(d,'10 · 12','Documentatiecheck','Ontvangen, op te vragen en ontbrekend','Controle van brondocumenten en stukken die nodig zijn voor financieringsbeoordeling.',`<div class="chart-grid-2"><div class="chart-card"><div class="chart-card-h">Status</div><div class="chart-card-t">Documentatieverdeling</div>${miniBars([{label:'Ontvangen',waarde:arr(doc.ontvangen).length||flat.filter(x=>/ontvangen/i.test(x.status||'')).length},{label:'Op te vragen',waarde:arr(doc.op_te_vragen).length||flat.filter(x=>/vragen/i.test(x.status||'')).length},{label:'Ontbrekend',waarde:arr(doc.ontbrekend).length||flat.filter(x=>/ontbre/i.test(x.status||'')).length},{label:'Niet in bron',waarde:arr(doc.niet_in_bron).length||flat.filter(x=>/niet/i.test(x.status||'')).length}])}</div><div>${table('Documentatiestatus',flat.length?flat:[...arr(doc.ontvangen).map(x=>({document:x,status:'Ontvangen'})),...arr(doc.op_te_vragen).map(x=>({document:x,status:'Op te vragen'})),...arr(doc.ontbrekend).map(x=>({document:x,status:'Ontbreekt'})),...arr(doc.niet_in_bron).map(x=>({document:x,status:'Niet in bron'}))],['document','status','toelichting'])}</div></div><div class="two-col"><div class="col-card"><div class="col-h">Ontbrekende stukken</div><div class="col-list">${listItems(arr(doc.ontbrekend))}</div></div><div class="col-card"><div class="col-h">Niet in bron / controleren</div><div class="col-list">${listItems(arr(doc.niet_in_bron))}</div></div></div>`)}
function advisorPage(d){const a=d.adviseur,c=d.controles,b=d.bijlagen;return page(d,'11 · 12','Adviseur-check & bijlagen','Openstaande punten, inconsistenties en bijlagenoverzicht','Controlepagina voor adviseur voordat het dossier naar financier of bank gaat.',`<div class="fin-strip"><div class="fin-cell"><div class="fin-l">Cijfers</div><div class="fin-v">${esc(n(c.cijfers_gevonden))}</div><div class="fin-s">gevonden velden</div></div><div class="fin-cell"><div class="fin-l">Teksten</div><div class="fin-v">${esc(n(c.teksten_gevonden))}</div><div class="fin-s">gevonden secties</div></div><div class="fin-cell"><div class="fin-l">Zekerheden</div><div class="fin-v">${esc(n(c.zekerheden_gevonden))}</div><div class="fin-s">gevonden items</div></div><div class="fin-cell"><div class="fin-l">Voorbeelddata</div><div class="fin-v">${c.voorbeelddata_gebruikt?'Ja':'Nee'}</div><div class="fin-s">agentcontrole</div></div></div><div class="two-col"><div class="col-card"><div class="col-h">Inconsistenties</div><div class="col-list">${listItems(arr(a.inconsistenties).concat(arr(c.inconsistenties)))}</div></div><div class="col-card"><div class="col-h">Actiepunten</div><div class="col-list">${listItems(arr(a.actiepunten).concat(arr(c.adviseur_check)))}</div></div></div><div class="two-col"><div>${table('Rechtspersonen',arr(b.rechtspersonen),['naam','rechtsvorm','kvk','vestiging'])}</div><div>${table('Privépersonen / betrokkenen',arr(b.privepersonen),['naam','rol','belang'])}</div></div>`)}
function closingPage(d){return page(d,'12 · 12','Slotpagina','Concept ter beoordeling','Afsluiting van het financieringsmemorandum met disclaimers en vervolgstappen.',`<div class="close-card"><div class="close-eyebrow">Credion MB</div><div class="close-title">Dit rapport is klaar voor adviseursreview.</div><div class="close-text">Controleer ontbrekende stukken, actuele bankopgaven, finale cijfers, zekerheden en voorwaarden voordat het dossier extern wordt gedeeld. Het rapport gebruikt uitsluitend de aangeleverde casusinformatie en markeert ontbrekende gegevens expliciet.</div></div><div class="two-col" style="margin-top:14px"><div class="col-card"><div class="col-h">Volgende stap</div><div class="col-list">${listItems(['Adviseur controleert inconsistenties en ontbrekende stukken.','Actuele financieringsvoorwaarden en bankopgaven toevoegen.','Definitieve versie exporteren naar PDF.'])}</div></div><div class="col-card"><div class="col-h">Rapportstatus</div><div class="col-list">${listItems([d.status,d.bronbasis,d.disclaimer])}</div></div></div>`)}

function kpiStrip(items){return `<div class="kpi-rapport">${items.map(([l,v,s])=>`<div class="kpi-r-cell"><div class="kpi-r-lbl">${esc(l)}</div><div class="kpi-r-val">${esc(txt(v))}</div><div class="kpi-r-sub">${esc(s||'')}</div></div>`).join('')}</div>`}
function scoreRows(items){return items.map(([l,v])=>`<div class="ss-row"><span class="ss-l">${esc(l)}</span><span class="ss-v">${esc(txt(v))}</span></div>`).join('')}
function note(title,value,highlight=false){return `<div class="note-card" style="${highlight?'background:linear-gradient(160deg,#F9FBFF,var(--blue-faint));':''}"><h4>${esc(title)}</h4><p>${esc(txt(value))}</p></div>`}
function listItems(items){const xs=arr(items);return xs.length?xs.map(x=>`<div>${esc(txt(x))}</div>`).join(''):`<div>${esc('Niet opgenomen in bron')}</div>`}
function listInline(items){const xs=arr(items);return xs.length?xs.map(x=>`• ${esc(txt(x))}`).join('<br>'):'Niet opgenomen in bron'}
function table(title,rows,cols){const r=arr(rows);if(!r.length)return `<div class="note-card"><h4>${esc(title)}</h4><div class="empty">Geen gegevens opgenomen in bron.</div></div>`;const columns=cols.filter(c=>r.some(row=>!isBlank(row?.[c])));const finalCols=columns.length?columns:cols.slice(0,3);return `<div class="note-card" style="padding:0;overflow:hidden"><h4 style="padding:13px 14px 0">${esc(title)}</h4><table class="premium-table" style="box-shadow:none;margin:8px 0 0;border-radius:0"><thead><tr>${finalCols.map(c=>`<th>${esc(human(c))}</th>`).join('')}</tr></thead><tbody>${r.slice(0,12).map(row=>`<tr>${finalCols.map(c=>{const val=row?.[c];const num=/bedrag|waarde|schuld|hoofdsom|verschil/i.test(c);return `<td class="${num?'num':''}">${esc(num?money(val):txt(val,''))}</td>`}).join('')}</tr>`).join('')}</tbody></table></div>`}
function sum(rows,key){return arr(rows).reduce((a,x)=>a+n(x?.[key]),0)}
function itemLabel(x){return x.label||x.post||x.rubriek||x.type||x.soort||x.verstrekker||x.naam||x.ratio||x.document||'Post'}
function barChart(items,valueKey='bedrag'){const xs=arr(items).map(x=>({label:itemLabel(x),value:Math.abs(n(x?.[valueKey]??x?.waarde??x?.restschuld??x?.score??x?.totaal))})).filter(x=>x.label&&x.value>0).slice(0,7);if(!xs.length)return `<div class="empty">Geen bedragen beschikbaar voor grafiek.</div>`;const max=Math.max(...xs.map(x=>x.value),1);return `<div class="mini-bars">${xs.map(x=>`<div class="mini-row"><div class="mini-l">${esc(x.label)}</div><div><div class="mini-track"><div class="mini-fill" style="width:${Math.round((x.value/max)*100)}%"></div></div><div class="mini-v">${esc(money(x.value))}</div></div></div>`).join('')}</div>`}
function miniBars(items){const xs=arr(items).map(x=>({label:x.label||x.ratio||x.naam||'Score',value:Math.abs(n(x.waarde??x.value??x.score))})).filter(x=>x.label).slice(0,7);if(!xs.length)return `<div class="empty">Geen scoredata beschikbaar.</div>`;const max=Math.max(...xs.map(x=>x.value),1);return `<div class="mini-bars">${xs.map(x=>`<div class="mini-row"><div class="mini-l">${esc(x.label)}</div><div><div class="mini-track"><div class="mini-fill" style="width:${Math.round((x.value/max)*100)}%"></div></div><div class="mini-v">${esc(new Intl.NumberFormat('nl-NL',{maximumFractionDigits:1}).format(x.value))}</div></div></div>`).join('')}</div>`}
function radarChart(items){const xs=arr(items).map(x=>({label:x.label||x.l||x.naam,value:clamp(x.waarde??x.v??x.score)})).filter(x=>x.label).slice(0,6);if(xs.length<3)return `<div class="empty">Onvoldoende data voor radar.</div>`;const cx=125,cy=105,r=72;const pts=xs.map((x,i)=>{const a=-Math.PI/2+i*(Math.PI*2/xs.length);const rr=r*(x.value/100);return [cx+Math.cos(a)*rr,cy+Math.sin(a)*rr]});const axes=xs.map((x,i)=>{const a=-Math.PI/2+i*(Math.PI*2/xs.length);return {x:cx+Math.cos(a)*r,y:cy+Math.sin(a)*r,lx:cx+Math.cos(a)*(r+22),ly:cy+Math.sin(a)*(r+22),label:x.label,value:x.value}});return `<svg viewBox="0 0 250 210" width="100%" height="170" role="img" aria-label="Radar chart"><polygon points="${axes.map(p=>`${p.x},${p.y}`).join(' ')}" fill="var(--blue-faint)" stroke="var(--blue-faint2)"/><g stroke="var(--blue-faint2)">${axes.map(p=>`<line x1="${cx}" y1="${cy}" x2="${p.x}" y2="${p.y}"/>`).join('')}</g><polygon points="${pts.map(p=>p.join(',')).join(' ')}" fill="rgba(15,99,253,.22)" stroke="var(--blue)" stroke-width="2"/><g>${pts.map(p=>`<circle cx="${p[0]}" cy="${p[1]}" r="3.2" fill="var(--orange)"/>`).join('')}</g><g>${axes.map(p=>`<text x="${p.lx}" y="${p.ly}" text-anchor="middle" font-size="8.5" font-weight="700" fill="var(--ink-3)">${esc(p.label).slice(0,16)}</text>`).join('')}</g></svg>`}
function trendChart(items){const xs=arr(items).map((x,i)=>({label:x.jaar||x.peildatum||x.label||x.ratio||`P${i+1}`,value:n(x.bedrag??x.waarde??x.score??x.percentage)})).filter(x=>x.value!==0).slice(0,8);if(xs.length<2)return `<div class="empty">Onvoldoende financiële tijdreeks voor trendgrafiek.</div>`;const w=260,h=130,p=24;const min=Math.min(...xs.map(x=>x.value),0),max=Math.max(...xs.map(x=>x.value),1);const pts=xs.map((x,i)=>{const px=p+i*((w-2*p)/(xs.length-1));const py=h-p-((x.value-min)/(max-min||1))*(h-2*p);return [px,py]});return `<svg viewBox="0 0 ${w} ${h}" width="100%" height="145" role="img" aria-label="Trend chart"><line x1="${p}" y1="${h-p}" x2="${w-p}" y2="${h-p}" stroke="var(--rule)"/><line x1="${p}" y1="${p}" x2="${p}" y2="${h-p}" stroke="var(--rule)"/><polyline points="${pts.map(p=>p.join(',')).join(' ')}" fill="none" stroke="var(--blue)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><g>${pts.map((p,i)=>`<circle cx="${p[0]}" cy="${p[1]}" r="3.5" fill="var(--orange)"/><text x="${p[0]}" y="${h-6}" text-anchor="middle" font-size="8" fill="var(--ink-3)">${esc(xs[i].label).slice(0,8)}</text>`).join('')}</g></svg>`}
function riskMatrix(items){const xs=arr(items).slice(0,4);let rows='<div class="mh">Risico</div><div class="mh">Kans</div><div class="mh">Impact</div><div class="mh">Mitigant</div>';if(!xs.length)xs.push({risico:'Niet opgenomen in bron',kans:'-',impact:'-',mitigant:'Aanvullen door adviseur'});rows+=xs.map(x=>`<div class="ml">${esc(txt(x.risico||x.label||x.naam))}</div><div>${esc(txt(x.kans,'-'))}</div><div>${esc(txt(x.impact,'-'))}</div><div>${esc(txt(x.mitigant||x.toelichting,'Aanvullen'))}</div>`).join('');return `<div class="matrix">${rows}</div>`}
</script>
</body>
</html>
